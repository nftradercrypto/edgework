# ─── SoDEX (read-only — no API key needed) ────────────────────────────────────
# Public read endpoints take {userAddress} in the URL and require no auth headers.
# This is the EVM wallet address you log into SoDEX with.
SODEX_USER_ADDRESS=
SODEX_BASE_URL=https://mainnet-gw.sodex.dev/api/v1


# ─── SoSoValue API ────────────────────────────────────────────────────────────
# Required for: regime tagging (SSI index history), ETF flows, sector rotation,
# news sentiment, and any live market context used by the AI Briefing.
#
# Get your key:
#   https://openapi.sosovalue.com/  →  Sign in  →  API Management  →  Create
#
# You can request higher rate limits via the SoSoValue Buildathon form.
SOSOVALUE_API_KEY=
SOSOVALUE_BASE_URL=https://openapi.sosovalue.com


# ─── Anthropic Claude (AI Briefing layer) ─────────────────────────────────────
# Required for: pre-session briefing generation.
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
