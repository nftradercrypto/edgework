# ─── SoDEX (read-only — no API key needed) ────────────────────────────────────
# Public read endpoints take {userAddress} in the URL and require no auth headers.
# This is the EVM wallet address you log into SoDEX with.
SODEX_USER_ADDRESS=
SODEX_BASE_URL=https://mainnet-gw.sodex.dev/api/v1


# ─── SoSoValue API ────────────────────────────────────────────────────────────
# Required for: regime tagging (SSI index history), ETF flows, sector rotation,
# news sentiment, and any live market context used by the AI Briefing.
#
# Get your key:
#   https://openapi.sosovalue.com/  →  Sign in  →  API Management  →  Create
#
# You can request higher rate limits via the SoSoValue Buildathon form.
SOSOVALUE_API_KEY=
SOSOVALUE_BASE_URL=https://openapi.sosovalue.com


# ─── Anthropic Claude (AI Briefing layer) ─────────────────────────────────────
# Required for: pre-session briefing generation.
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6


# ─── Execution companion (LOCAL ONLY — Wave 3) ────────────────────────────────
# Used exclusively by scripts/edgework_exec.py running on YOUR machine.
# NEVER set these on a hosted deployment — the hosted app runs simulation only.
#
# SODEX_API_PRIVATE_KEY is the private key of a SoDEX *API key* — a delegated,
# revocable signing key you create on SoDEX. It is NOT your wallet seed phrase.
# You can revoke it on SoDEX at any time.
#SODEX_ACCOUNT_ID=
#SODEX_API_PRIVATE_KEY=
#SODEX_NETWORK=mainnet


# ─── Discord divergence alerts (LOCAL — Wave 3) ───────────────────────────────
# Used by scripts/alert_bot.py to post Smart Money Divergence alerts to your
# Discord channel. Read-only: the bot never signs or sends orders, it just
# watches SODEX_USER_ADDRESS and posts when you open a contrarian position.
# Create the webhook in Discord: Server Settings → Integrations → Webhooks.
#EDGEWORK_DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
