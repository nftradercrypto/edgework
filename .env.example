# SoDEX (read-only — no API key needed, just your wallet address)
# Read endpoints take {userAddress} in the URL and require no auth headers.
# This is your EVM wallet address, the one you use to log into SoDEX.
SODEX_USER_ADDRESS=
SODEX_BASE_URL=https://mainnet-gw.sodex.dev/api/v1

# SoSoValue API
# Apply for higher limits via the Buildathon form if needed.
SOSOVALUE_API_KEY=
SOSOVALUE_BASE_URL=https://openapi.sosovalue.com

# Anthropic Claude (for AI Briefing layer)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
